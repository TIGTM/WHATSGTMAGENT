# Nome da empresa e estilo de conversa
COMPANY_NAME=GTM Alimentos
AGENT_NAME=GTM Assistente

# Links Gerais
SALES_URL=https://sualoja.com.br
EMPLOYEE_PORTAL_URL=https://gtmalimentos.intranet
PARTNER_REGISTRATION_URL=https://gtmalimentos.com.br/parceiros
SUPPLIER_CONTACT=vendas1@gtmdistribuidora.com.br

# API de IA opcional (Gemini via endpoint REST)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Provedor de IA: auto | gemini | ollama
LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Limita o tamanho do contexto global carregado nos prompts (performance em VPS)
MAX_GLOBAL_CONTEXT_CHARS=12000

# Credenciais OAuth2 Sankhya
SANKHYA_CLIENT_ID=
SANKHYA_CLIENT_SECRET=
SANKHYA_APPKEY=

# Libera operações de escrita no ERP (save/delete/execute/rest mutável)
ERP_WRITE_ENABLED=false

# Senha da Diretoria
DIRECTOR_PIN=AcessoGTM2024

# Configuração do bot
WELCOME_MESSAGE=Bem-vindo(a) a GTM Alimentos, Q'Pescado e Pescados Bem Fresco!
HUMAN_HANDOFF_PHONE=5511999999999
